{
    "name": "napoleonic-client",
    "version": "1.2.0",
    "description": "Client for Napoleonic Uniformology",
    "author": "Joel Brighton (joebri)",
    "private": true,
    "license": "ISC",
    "keywords": [],
    "engines": {
        "node": "25.1.0"
    },
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/joebri/napoleonic-client.git"
    },
    "scripts": {
        "start:dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "lint": "eslint src/**/*.ts src/**/*.tsx --max-warnings=0",
        "prepare": "husky install",
        "docker:serve": "serve -s /app",
        "docker:up": "docker-compose --file docker-compose.prod.yml up --detach",
        "docker:down": "docker-compose --file docker-compose.prod.yml down"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/lodash": "^4.17.24",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint-config-react-app": "^7.0.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "identity-obj-proxy": "^3.0.0",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "vite": "^8.1.0",
        "vite-plugin-eslint": "^1.8.1",
        "vitest": "^4.1.9",
        "web-vitals": "^5.3.0"
    },
    "dependencies": {
        "@apollo/client": "^4.2.3",
        "@apollo/sandbox": "^2.7.4",
        "@auth0/auth0-react": "^2.19.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.2.0",
        "@mui/material": "^9.2.0",
        "@mui/system": "^9.1.2",
        "@sentry/browser": "^10.62.0",
        "@sentry/react": "^10.62.0",
        "@tiptap/extension-bubble-menu": "^3.27.1",
        "@tiptap/extension-color": "^3.27.1",
        "@tiptap/extension-link": "^3.27.1",
        "@tiptap/extension-table": "^3.27.1",
        "@tiptap/extension-text-style": "^3.27.1",
        "@tiptap/pm": "^3.27.1",
        "@tiptap/react": "^3.27.1",
        "@tiptap/starter-kit": "^3.27.1",
        "@vitejs/plugin-react": "^6.0.3",
        "cra-template-typescript": "1.3.0",
        "dotenv": "^17.4.2",
        "graphql": "^17.0.1",
        "history": "^5.3.0",
        "husky": "^9.1.7",
        "jotai": "^2.20.1",
        "lodash.debounce": "^4.0.8",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-helmet-async": "^3.0.0",
        "react-router-dom": "^7.18.0",
        "sass": "^1.101.0",
        "tslib": "^2.8.1"
    },
    "overrides": {},
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
